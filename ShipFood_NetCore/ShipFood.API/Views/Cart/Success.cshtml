@model int

@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-xxl py-5 wow fadeInUp" data-wow-delay="0.1s">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <i class="bi bi-check-circle-fill text-primary display-1"></i>
                <h1 class="display-1">Đặt Hàng Thành Công!</h1>
                <h1 class="mb-4">Cảm ơn bạn đã tin tưởng Fastship</h1>
                <p class="mb-4">Đơn hàng của bạn đã được tiếp nhận và sẽ sớm được giao đến bạn. Mã đơn hàng của bạn là: <strong>#@Model</strong></p>
                <div class="d-flex justify-content-center gap-2">
                     <a class="btn btn-primary rounded-pill py-3 px-5" href="/Home/DanhMuc">Tiếp tục mua sắm</a>
                     <!-- If user is logged in, show link to history, otherwise just home. 
                          Ideally we check session, but simple link is fine -->
                     <a class="btn btn-secondary rounded-pill py-3 px-5" href="/Home">Về trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>
