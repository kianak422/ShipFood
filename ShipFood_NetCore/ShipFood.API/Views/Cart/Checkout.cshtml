@model ShipFood.API.Models.Cart
@{
    ViewData["Title"] = "Thanh toán";
}

<!-- Checkout Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4">Chi tiết thanh toán</h1>
        <form action="/Cart/Checkout" method="post">
            <div class="row g-5">
                <!-- Cột thông tin khách hàng -->
                <div class="col-md-12 col-lg-6 col-xl-7">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-item w-100">
                                <label class="form-label my-3">Họ Tên người nhận<sup>*</sup></label>
                                <input type="text" name="hoten" class="form-control" value="@ViewBag.Hoten" required>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-item w-100">
                                <label class="form-label my-3">Số điện thoại<sup>*</sup></label>
                                <input type="text" name="sdt" class="form-control" required>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-item w-100">
                                <label class="form-label my-3">Địa chỉ giao hàng (Số nhà, Phường, Quận)<sup>*</sup></label>
                                <input type="text" name="diachi" class="form-control" required>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-item w-100">
                                <label class="form-label my-3">Ghi chú (Tùy chọn)</label>
                                <textarea name="ghichu" class="form-control" spellcheck="false" cols="30" rows="5" placeholder="Ghi chú thêm về đơn hàng..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cột hiển thị hóa đơn và thanh toán -->
                <div class="col-md-12 col-lg-6 col-xl-5">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">Sản phẩm</th>
                                    <th scope="col">Tên</th>
                                    <th scope="col">Giá</th>
                                    <th scope="col">SL</th>
                                    <th scope="col">Tổng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.MonAns)
                                {
                                    <tr>
                                        <th scope="row">
                                            <div class="d-flex align-items-center mt-2">
                                                <img src="@(!string.IsNullOrEmpty(item.Hinhanh) ? item.Hinhanh : "/home/img/no-image.jpg")" class="img-fluid rounded-circle" style="width: 50px; height: 50px;" alt="">
                                            </div>
                                        </th>
                                        <td class="py-3">@item.Tenmon</td>
                                        <td class="py-3">@item.Giatien.ToString("N0")</td>
                                        <td class="py-3">@item.SoLuong</td>
                                        <td class="py-3">@((item.Giatien * item.SoLuong).ToString("N0")) đ</td>
                                    </tr>
                                }
                    <div class="table-responsive">
                        <table class="table">
                            <!-- Bảng tóm tắt tiền -->
                            <tbody>
                                <tr>
                                    <th scope="row"></th>
                                    <td class="py-3"></td>
                                    <td class="py-3"></td>
                                    <td class="py-3">
                                        <p class="mb-0 text-dark py-2">Tạm tính</p>
                                    </td>
                                    <td class="py-3">
                                        <div class="py-2 border-bottom border-top text-end">
                                            <p class="mb-0 text-dark" id="txt-subtotal" data-value="@Model.TongTien">@Model.TongTien.ToString("N0") đ</p>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row"></th>
                                    <td class="py-3"></td>
                                    <td class="py-3"></td>
                                    <td class="py-3">
                                        <p class="mb-0 text-dark py-2">Phí Ship</p>
                                    </td>
                                    <td class="py-3">
                                        <div class="py-2 border-bottom text-end">
                                            <p class="mb-0 text-dark">15,000 đ</p>
                                        </div>
                                    </td>
                                </tr>
                                <tr id="row-discount" style="display: none;">
                                    <th scope="row"></th>
                                    <td class="py-3"></td>
                                    <td class="py-3"></td>
                                    <td class="py-3">
                                        <p class="mb-0 text-success fw-bold py-2">Khuyến mãi</p>
                                    </td>
                                    <td class="py-3">
                                        <div class="py-2 border-bottom text-end">
                                            <p class="mb-0 text-success fw-bold" id="txt-discount">-0 đ</p>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <th scope="row"></th>
                                    <td class="py-3"></td>
                                    <td class="py-3"></td>
                                    <td class="py-3">
                                        <p class="mb-0 text-dark text-uppercase py-3">Tổng cộng</p>
                                    </td>
                                    <td class="py-3">
                                        <div class="py-3 border-bottom text-end">
                                            <p class="mb-0 text-dark fw-bold text-danger fs-5" id="txt-final-total">@((Model.TongTien + 15000).ToString("N0")) đ</p>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Khung Nhập Mã Giảm Giá -->
                    <div class="row g-4 text-center align-items-center justify-content-center p-4 rounded bg-light mt-3">
                        <div class="col-12 text-start">
                            <h5 class="mb-3 text-primary"><i class="fa fa-tag me-2"></i>Mã Giảm Giá (Coupon)</h5>
                            <div class="input-group mb-2">
                                <input type="text" id="couponCodeInput" name="couponCode" class="form-control" placeholder="Nhập mã khuyến mãi..." autocomplete="off">
                                <button class="btn btn-primary text-white" type="button" id="btn-apply-coupon">Áp dụng</button>
                            </div>
                            <small id="coupon-message" class="fw-bold d-block mt-1"></small>
                            <!-- Gợi ý mã cho khách dễ chọn (Demo App) -->
                            <small class="text-muted d-block mt-2">Mã hôm nay:</small>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                <span class="badge bg-secondary cursor-pointer" onclick="$('#couponCodeInput').val('MAMOI')">MAMOI (Giảm 10% Đồ ăn)</span>
                                <span class="badge bg-secondary cursor-pointer" onclick="$('#couponCodeInput').val('FREETRASUA')">FREETRASUA (Free Đồ uống)</span>
                                <span class="badge bg-secondary cursor-pointer" onclick="$('#couponCodeInput').val('GIAM20K')">GIAM20K (Giảm Nhẹ Đồ ăn vặt)</span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 text-center align-items-center justify-content-center p-4 rounded bg-light mt-3">
                        <div class="col-12 text-start">
                            <h5 class="mb-3">Phương thức thanh toán</h5>
                            <div class="form-check my-3">
                                <input class="form-check-input" type="radio" name="phuongthuc" id="payment-cod" value="COD" checked>
                                <label class="form-check-label" for="payment-cod">
                                    Thanh toán khi nhận hàng (COD)
                                </label>
                            </div>
                            <div class="form-check my-3">
                                <input class="form-check-input" type="radio" name="phuongthuc" id="payment-qr" value="ONLINE">
                                <label class="form-check-label" for="payment-qr">
                                    Chuyển khoản Ví điện tử (ZaloPay / Momo / Bank)
                                </label>
                            </div>
                            
                            <!-- Bảng Quét QR (Ẩn mặc định) -->
                            <div id="qr-section" class="text-center w-100 alert alert-info mt-3" style="display: none;">
                                <p class="fw-bold text-dark">Vui lòng quét mã QR dưới đây để thanh toán</p>
                                <img src="https://upload.wikimedia.org/wikipedia/commons/d/d0/QR_code_for_mobile_English_Wikipedia.svg" class="img-fluid bg-white p-2 rounded mb-3" style="max-width: 200px;" alt="QR Code">
                                <p>Số tiền: <strong id="qr-total" class="text-danger fs-5">@((Model.TongTien + 15000).ToString("N0")) đ</strong></p>
                                
                                <button type="button" id="btn-scanned" class="btn btn-warning w-100 rounded-pill py-2 text-dark fw-bold mb-2">Đã Quét & Hoàn Tất Chuyển Khoản</button>
                                <p id="qr-success-msg" class="text-success fw-bold mt-2 mb-0" style="display: none;"><i class="fa fa-check-circle me-1"></i>Xác nhận chuyển khoản thành công!</p>
                            </div>
                        </div>
                    </div>
                    
                    <button type="submit" id="btn-submit-order" class="btn border-secondary py-3 px-4 text-uppercase w-100 text-primary fw-bold mt-4" style="border-radius: 8px;">
                        Đặt đơn
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Checkout Page End -->

@section Scripts {
    <script>
        $(document).ready(function() {
            var btnSubmit = $('#btn-submit-order');
            var qrSection = $('#qr-section');
            var btnScanned = $('#btn-scanned');
            var successMsg = $('#qr-success-msg');
            
            var originalSubTotal = parseInt($('#txt-subtotal').data('value'));
            var shipFee = 15000;
            var currentDiscount = 0;

            function formatCurrency(amount) {
                return amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",") + " đ";
            }

            function updateTotals() {
                var finalTotal = originalSubTotal + shipFee - currentDiscount;
                if (finalTotal < 0) finalTotal = 0;
                $('#txt-final-total').text(formatCurrency(finalTotal));
                $('#qr-total').text(formatCurrency(finalTotal));
            }

            // Xử lý nút Apply Mã Giảm Giá qua AJAX
            $('#btn-apply-coupon').click(function() {
                var code = $('#couponCodeInput').val();
                $.ajax({
                    url: '/Cart/GetDiscountAmount',
                    type: 'POST',
                    data: { couponCode: code },
                    success: function(res) {
                        var msgLabel = $('#coupon-message');
                        if (res.success) {
                            currentDiscount = res.discount;
                            msgLabel.removeClass('text-danger').addClass('text-success').text(res.message);
                            $('#row-discount').show();
                            $('#txt-discount').text("-" + formatCurrency(currentDiscount));
                        } else {
                            currentDiscount = 0;
                            msgLabel.removeClass('text-success').addClass('text-danger').text(res.message);
                            $('#row-discount').hide();
                        }
                        updateTotals();
                    },
                    error: function() {
                        alert("Lỗi kết nối khi kiểm tra mã giảm giá.");
                    }
                });
            });

            // Xử lý khi đổi phương thức thanh toán
            $('input[name="phuongthuc"]').change(function() {
                if ($('#payment-qr').is(':checked')) {
                    // Nếu chọn Trả trước qua mạng
                    qrSection.slideDown();
                    btnSubmit.prop('disabled', true);
                    btnSubmit.removeClass('text-primary').addClass('text-muted');
                    btnSubmit.html('<i class="fa fa-lock me-2"></i>Vui lòng quét mã QR trước');
                    
                    // Reset trạng thái "Đã quét" nếu đổi qua đổi lại
                    successMsg.hide();
                    btnScanned.show();
                } else {
                    // Nếu đổi về COD
                    qrSection.slideUp();
                    btnSubmit.prop('disabled', false);
                    btnSubmit.removeClass('text-muted').addClass('text-primary');
                    btnSubmit.html('Đặt đơn');
                }
            });
            
            // Xử lý khi bấm nút "Đã Quét"
            btnScanned.click(function() {
                // Giả lập logic check mã thành công (Mở nút Đặt đơn)
                $(this).fadeOut(300, function() {
                    successMsg.fadeIn(300);
                    btnSubmit.prop('disabled', false);
                    btnSubmit.removeClass('text-muted').addClass('text-primary');
                    btnSubmit.html('<i class="fa fa-check me-2"></i>Đặt đơn');
                });
            });
        });
    </script>
}
