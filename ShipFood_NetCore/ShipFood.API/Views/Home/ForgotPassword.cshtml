@model ShipFood.API.Models.TbUser
@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quên mật khẩu - Fastship</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="/home/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/home/css/login.css" rel="stylesheet" />
</head>

<body class="bg-light">
    <div class="container-fluid bg-white shadow-sm">
        <div class="container">
            <div class="row align-items-center py-3">
                <div class="col-lg-4">
                    <a href="/Home" class="navbar-brand">
                        <h1 style="color: #3CB815 !important;" class="fw-bold text-primary m-0">
                            F<span style="color: #F65005 !important;" class="text-secondary">ast</span>ship
                        </h1>
                    </a>
                </div>
                <div class="col-lg-8 text-end">
                    <span class="text-muted">Đã nhớ mật khẩu? </span>
                    <a href="/Home/Login" class="text-primary text-decoration-none fw-bold">Đăng nhập ngay</a>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-lg-5 col-md-7 col-sm-9">
                <div class="card shadow-lg border-0">
                    <div class="card-header text-white text-center py-4">
                        <h3 class="fw-light my-2">
                            <i class="fas fa-key me-2"></i>
                            Quên mật khẩu
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        @if (ViewBag.Message != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="fas fa-check-circle me-2"></i>
                                <span>@ViewBag.Message</span>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }
                        
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                <span>@ViewBag.Error</span>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <p class="text-muted mb-4 text-center">Nhập thông tin xác thực để đặt lại mật khẩu mới.</p>
                        <form action="/Home/ForgotPassword" method="post" class="needs-validation" novalidate>
                            <div class="form-floating mb-3">
                                <input class="form-control" 
                                       id="inputEmail" 
                                       type="email" 
                                       name="email"
                                       placeholder="Email" 
                                       required />
                                <label for="inputEmail">
                                    <i class="fas fa-envelope me-2"></i>
                                    Email đăng ký
                                </label>
                            </div>

                            <div class="form-floating mb-3">
                                <input class="form-control" 
                                       id="inputSdt" 
                                       type="tel" 
                                       name="sdt"
                                       placeholder="Số điện thoại" 
                                       required />
                                <label for="inputSdt">
                                    <i class="fas fa-phone me-2"></i>
                                    Số điện thoại
                                </label>
                            </div>
                            
                            <hr class="my-4">
                            
                            <div class="form-floating mb-3">
                                <input class="form-control" 
                                       id="inputNewPassword" 
                                       type="password" 
                                       name="newPassword"
                                       placeholder="Mật khẩu mới" 
                                       required />
                                <label for="inputNewPassword">
                                    <i class="fas fa-lock me-2"></i>
                                    Mật khẩu mới
                                </label>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button class="btn btn-primary btn-lg" type="submit">
                                    <i class="fas fa-save me-2"></i>
                                    Đổi mật khẩu
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="card-footer text-center py-3">
                        <div class="small">
                            <a href="/Home/Login" class="text-decoration-none fw-bold">
                                <i class="fas fa-arrow-left me-1"></i>
                                Quay lại đăng nhập
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
