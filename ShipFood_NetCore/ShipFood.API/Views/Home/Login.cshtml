@model ShipFood.API.Models.TbUser
@{
    Layout = null; // Login page usually has its own layout or full page
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập - Fastship</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content="fastship, đặt hàng, giao hàng, ẩm thực, thức ăn" name="keywords" />
    <meta content="Fastship - Nền tảng đặt hàng và giao hàng thức ăn hàng đầu Việt Nam" name="description" />
    
    <!-- Favicon -->
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <link href="/home/img/favicon.ico" rel="icon" />

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Bootstrap CSS -->
    <link href="/home/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Custom Login CSS -->
    <link href="/home/css/login.css" rel="stylesheet" />
</head>

<body class="bg-light">
    <!-- Header Start -->
    <div class="container-fluid bg-white shadow-sm">
        <div class="container">
            <div class="row align-items-center py-3">
                <div class="col-lg-4">
                    <a href="/Home" class="navbar-brand">
                        <h1 style="color: #3CB815 !important;" class="fw-bold text-primary m-0">
                            F<span style="color: #F65005 !important;" class="text-secondary">ast</span>ship
                        </h1>
                    </a>
                </div>
                <div class="col-lg-8 text-end">
                    <span class="text-muted">Chưa có tài khoản? </span>
                    <a href="/Home/Signup" class="text-primary text-decoration-none fw-bold">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Header End -->

    <!-- Login Form Start -->
    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-lg-5 col-md-7 col-sm-9">
                <div class="card shadow-lg border-0">
                    <div class="card-header text-white text-center py-4">
                        <h3 class="fw-light my-2">
                            <i class="fas fa-sign-in-alt me-2"></i>
                            Đăng nhập
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        <!-- Error Message -->
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <span>@ViewBag.Error</span>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form action="/Home/Login" method="post" class="needs-validation" novalidate>
                            <div class="form-floating mb-3">
                                <input class="form-control" 
                                       id="inputUsername" 
                                       type="text" 
                                       name="username"
                                       placeholder="Tên đăng nhập" 
                                       required />
                                <label for="inputUsername">
                                    <i class="fas fa-user me-2"></i>
                                    Tên đăng nhập
                                </label>
                                <div class="invalid-feedback">
                                    Vui lòng nhập tên đăng nhập.
                                </div>
                            </div>
                            
                            <div class="form-floating mb-3">
                                <input class="form-control" 
                                       id="inputPassword" 
                                       type="password" 
                                       name="password"
                                       placeholder="Mật khẩu" 
                                       required />
                                <label for="inputPassword">
                                    <i class="fas fa-lock me-2"></i>
                                    Mật khẩu
                                </label>
                                <div class="invalid-feedback">
                                    Vui lòng nhập mật khẩu.
                                </div>
                            </div>
                            
                            <div class="form-check mb-4">
                                <input class="form-check-input" id="inputRememberPassword" type="checkbox" name="remember" />
                                <label class="form-check-label" for="inputRememberPassword">
                                    <i class="fas fa-remember me-1"></i>
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                            
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <a class="small text-decoration-none" href="/Home/ForgotPassword">
                                    <i class="fas fa-question-circle me-1"></i>
                                    Quên mật khẩu?
                                </a>
                                <button class="btn btn-primary px-4" type="submit">
                                    <i class="fas fa-sign-in-alt me-2"></i>
                                    Đăng nhập
                                </button>
                            </div>
                        </form>

                        <!-- Social Login Removed as requested -->
                    </div>
                    <div class="card-footer text-center py-3">
                        <div class="small">
                            <span class="text-muted">Chưa có tài khoản? </span>
                            <a href="/Home/Signup" class="text-decoration-none fw-bold">
                                <i class="fas fa-user-plus me-1"></i>
                                Đăng ký ngay!
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Login Form End -->

    <!-- Footer Start -->
    <div class="container-fluid bg-dark footer mt-5 pt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="text-light">&copy; <a href="#" class="border-bottom text-light">Fastship</a>, Tất cả quyền được bảo lưu.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <span class="text-light">Được thiết kế bởi <a href="#" class="border-bottom text-light">Fastship Team</a></span>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        (function() {
            'use strict';
            window.addEventListener('load', function() {
                var forms = document.getElementsByClassName('needs-validation');
                var validation = Array.prototype.filter.call(forms, function(form) {
                    form.addEventListener('submit', function(event) {
                        if (form.checkValidity() === false) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            }, false);
        })();
    </script>
</body>
</html>
