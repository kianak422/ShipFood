@model IEnumerable<ShipFood.API.Models.TbTonKho>

@{
Layout = "_AdminLayout";
ViewData["Title"] = "Quản lý tồn kho";
}

<!-- Thống kê -->

<div class="row g-4 mb-4">

```
<div class="col-md-3">
    <div class="card text-white bg-primary h-100 shadow">
        <div class="card-body">
            <h5 class="card-title">
                <i class="fas fa-boxes fa-2x float-end"></i>
                Mặt hàng
            </h5>

            <h2 class="display-6">
                @Model.Count()
            </h2>

            <p class="card-text">
                Tổng số mặt hàng
            </p>

        </div>
    </div>
</div>

<div class="col-md-3">
    <div class="card text-white bg-success h-100 shadow">
        <div class="card-body">
            <h5 class="card-title">
                <i class="fas fa-warehouse fa-2x float-end"></i>
                Tồn kho
            </h5>

            <h2 class="display-6">
                @Model.Sum(x => x.SoLuongTon)
            </h2>

            <p class="card-text">
                Tổng số lượng tồn
            </p>

        </div>
    </div>
</div>

<div class="col-md-3">
    <div class="card text-white bg-warning h-100 shadow">
        <div class="card-body">
            <h5 class="card-title">
                <i class="fas fa-arrow-down fa-2x float-end"></i>
                Đã nhập
            </h5>

            <h2 class="display-6">
                @Model.Sum(x => x.SoLuongNhap)
            </h2>

            <p class="card-text">
                Tổng hàng đã nhập
            </p>

        </div>
    </div>
</div>

<div class="col-md-3">
    <div class="card text-white bg-danger h-100 shadow">
        <div class="card-body">
            <h5 class="card-title">
                <i class="fas fa-exclamation-triangle fa-2x float-end"></i>
                Sắp hết
            </h5>

            <h2 class="display-6">
                @Model.Count(x => x.SoLuongTon < 10)
            </h2>

            <p class="card-text">
                Sản phẩm sắp hết hàng
            </p>

        </div>
    </div>
</div>
```

</div>

<!-- Bộ lọc -->

<div class="card shadow mb-4">
    <div class="card-body">

        <form method="get" asp-action="Index">

            <div class="row g-3">

                <div class="col-md-5">
                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control"
                           placeholder="🔍 Tìm theo tên món ăn..." />
                </div>

                <div class="col-md-3">
                    <select name="status" class="form-select">

                        <option value="">-- Tất cả trạng thái --</option>

                        <option value="many"
                                selected="@(ViewBag.Status == "many")">
                            Còn nhiều
                        </option>

                        <option value="medium"
                                selected="@(ViewBag.Status == "medium")">
                            Trung bình
                        </option>

                        <option value="low"
                                selected="@(ViewBag.Status == "low")">
                            Sắp hết
                        </option>

                        <option value="empty"
                                selected="@(ViewBag.Status == "empty")">
                            Hết hàng
                        </option>

                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit"
                            class="btn btn-primary w-100">
                        <i class="fas fa-search"></i>
                        Lọc
                    </button>
                </div>

                <div class="col-md-2">
                    <a asp-action="Index"
                       class="btn btn-secondary w-100">
                        <i class="fas fa-sync"></i>
                        Reset
                    </a>
                </div>

            </div>

        </form>

    </div>
</div>

<!-- Danh sách tồn kho -->

<div class="card shadow mb-4">

```
<div class="card-header py-3 d-flex justify-content-between align-items-center">

    <h6 class="m-0 font-weight-bold text-primary">

        Danh sách tồn kho

    </h6>

    <a asp-action="Create"
       class="btn btn-success">

        <i class="fas fa-plus"></i>

        Nhập kho

    </a>

</div>

<div class="card-body">

    <div class="table-responsive">

        <table class="table table-bordered table-hover">

            <thead>

                <tr>
                    <th>Mã kho</th>
                    <th>Ảnh</th>
                    <th>Món ăn</th>
                    <th>Tồn kho</th>
                    <th>Đã nhập</th>
                    <th>Cập nhật</th>
                    <th>Trạng thái</th>
                    <th width="150">Thao tác</th>
                </tr>

            </thead>

            <tbody>

                @foreach(var item in Model)
                {
                    <tr>

                        <td>
                            #@item.MaKho
                        </td>

                        <td>

                            <img src="@item.MonAn?.Hinhanh"
                                 width="60"
                                 height="60"
                                 style="object-fit:cover;border-radius:8px;" />

                        </td>

                        <td>

                            <strong>
                                @item.MonAn?.Tenmon
                            </strong>

                        </td>

                        <td>

                            @item.SoLuongTon

                        </td>

                        <td>

                            @item.SoLuongNhap

                        </td>

                        <td>

                            @(item.NgayCapNhat?.ToString("dd/MM/yyyy"))

                        </td>

                        <td>

                            @if(item.SoLuongTon < 10)
                            {
                                <span class="badge bg-danger">
                                    Sắp hết
                                </span>
                            }
                            else if(item.SoLuongTon < 30)
                            {
                                <span class="badge bg-warning text-dark">
                                    Trung bình
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    Còn nhiều
                                </span>
                            }

                        </td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-MaKho="@item.MaKho"
                               class="btn btn-warning btn-sm">

                                <i class="fas fa-edit"></i>

                            </a>

                            <a asp-action="Delete"
                               asp-route-MaKho="@item.MaKho"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bạn có chắc chắn xóa mặt hàng này hay không?')">

                                <i class="fas fa-trash"></i>

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
```

</div>
