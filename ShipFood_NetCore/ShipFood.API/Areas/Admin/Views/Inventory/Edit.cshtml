@model ShipFood.API.Models.TbTonKho

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cập nhật tồn kho";
}

<div class="card shadow border-0">

    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">
            <i class="fas fa-edit me-2"></i>
            Cập nhật tồn kho
        </h4>
    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post">

            <input asp-for="MaKho" type="hidden"/>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Món ăn
                </label>

                <select asp-for="Mamon"
                        class="form-select">

                    @foreach (var item in ViewBag.MonAn)
                    {
                        <option value="@item.Mamon">
                            @item.Tenmon
                        </option>
                    }

                </select>
            </div>

            <div class="mb-3">

                <label class="form-label fw-bold">
                    Số lượng tồn
                </label>

                <input asp-for="SoLuongTon"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label class="form-label fw-bold">
                    Số lượng nhập
                </label>

                <input asp-for="SoLuongNhap"
                       class="form-control" />

            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Giá nhập
                </label>
                <input asp-for="GiaNhap" class="form-control" />
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">
                    Giá bán
                </label>
                <input asp-for="GiaBan" class="form-control" />
            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-warning">

                    <i class="fas fa-save"></i>
                    Cập nhật

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Quay lại

                </a>

            </div>

        </form>

    </div>

</div>