<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Fastship</title>

    <!-- Template Fonts & Styles -->
    <link href="/home/css/style.css" rel="stylesheet" />
    <link href="/home/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            font-family: "Open Sans", sans-serif;
            background-color: #F7F8FC;
        }

        /* Sidebar Styling matching Hero Gradient */
        .sidebar {
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            padding-top: 20px;
            /* Gradient matching .page-header */
            background: linear-gradient(135deg, rgba(60, 184, 21, 0.9) 0%, rgba(246, 80, 5, 0.9) 100%), url('/home/img/hero-bg.jpg');
            background-size: cover;
            color: #fff;
            box-shadow: 4px 0 10px rgba(0, 0, 0, 0.1);
            z-index: 1000;
        }

        .sidebar h3 {
            color: #fff !important;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
        }

        .sidebar a {
            padding: 15px 25px;
            text-decoration: none;
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.8);
            display: block;
            transition: 0.3s;
            border-radius: 0 25px 25px 0;
            margin-right: 15px;
        }

        .sidebar a:hover,
        .sidebar a.active {
            color: #3CB815;
            background-color: #fff;
            font-weight: 600;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .main-content {
            margin-left: 250px;
            padding: 30px;
        }

        /* Card Styling */
        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 0 45px rgba(0, 0, 0, .07);
            /* Matching .product-item */
            transition: .5s;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .btn-primary {
            background-color: #3CB815;
            border-color: #3CB815;
            border-radius: 50px;
            /* Rounded pill buttons */
            padding: 8px 20px;
        }

        .btn-primary:hover {
            background-color: #2ea309;
        }

        .table thead {
            background-color: #3CB815;
            color: white;
            border-radius: 10px 10px 0 0;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="text-center mb-4">
                     <h1 style="color: #ffffff !important;" class="fw-bold text-primary m-0">
                        F<span style="color: #F65005 !important;" class="text-secondary">ast</span>ship
                    </h1>
                </div>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"><i
                        class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
                <a asp-area="Admin" asp-controller="User" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"><i
                        class="fas fa-users me-2"></i> Người dùng</a>
                <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"><i
                        class="fas fa-list me-2"></i> Danh mục</a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"><i
                        class="fas fa-utensils me-2"></i> Món ăn</a>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"><i
                        class="fas fa-shopping-cart me-2"></i> Đơn hàng</a>
                <a asp-area="Admin" asp-controller="Voucher" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Voucher" ? "active" : "")"><i
                        class="fas fa-ticket-alt me-2"></i> Voucher</a>   
                <a asp-area="Admin" asp-controller="Banner" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Banner" ? "active" : "")">
                    <i class="fas fa-image me-2"></i> Banner</a>
                <a asp-area="Admin" asp-controller="Inventory" asp-action="Index"
                    class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")">
                    <i class="fas fa-box me-2"></i> Tồn kho</a>
                <a href="/Home/Index"><i class="fas fa-sign-out-alt me-2"></i> Về Website</a>
            </div>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                <div
                    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">@ViewData["Title"]</h1>
                    <div class="btn-toolbar mb-2 mb-md-0">
                        <span class="text-muted">Xin chào, Admin</span>
                    </div>
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
