@model IEnumerable<ShipFood.API.Models.TbVoucher>

@{
    ViewData["Title"] = "Quản lý Voucher";
}

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <h4>Danh sách Voucher</h4>

        <a asp-action="Create"
           class="btn btn-primary">
            Thêm Voucher
        </a>
    </div>

    <div class="card-body">

        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Code</th>
                    <th>Giảm giá</th>
                    <th>Ngày bắt đầu</th>
                    <th>Ngày kết thúc</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

            @foreach(var item in Model)
            {
                <tr>

                    <td>@item.Code</td>

                    <td>
                        @(item.IsPercent
                            ? item.DiscountValue + "%"
                            : item.DiscountValue.ToString("N0") + " VNĐ")
                    </td>

                    <td>@item.StartDate.ToString("dd/MM/yyyy")</td>

                    <td>@item.EndDate.ToString("dd/MM/yyyy")</td>

                    <td>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Xóa
                        </a>

                    </td>

                </tr>
            }

            </tbody>

        </table>

    </div>
</div>