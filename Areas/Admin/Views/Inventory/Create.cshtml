@model ShipFood.API.Models.TbTonKho

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nhập kho";
}

<div class="card shadow border-0">

    <div class="card-header bg-success text-white">
        <h4 class="mb-0">
            <i class="fas fa-warehouse me-2"></i>
            Nhập hàng vào kho
        </h4>
    </div>

    <div class="card-body p-4">

        <form asp-action="Create" method="post">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label fw-bold">
                        Món ăn
                    </label>

                    <select asp-for="Mamon"
                            class="form-select"
                            required>

                        <option value="">
                            -- Chọn món ăn --
                        </option>

                        @foreach (var item in ViewBag.MonAn)
                        {
                            <option value="@item.Mamon">
                                @item.Tenmon
                            </option>
                        }

                    </select>

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label fw-bold">
                        Số lượng nhập
                    </label>

                    <input asp-for="SoLuongNhap"
                           class="form-control"
                           min="1"
                           placeholder="Nhập số lượng..." />

                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label fw-bold">
                        Số lượng tồn hiện tại
                    </label>

                    <input asp-for="SoLuongTon"
                           class="form-control"
                           min="0"
                           placeholder="Nhập tồn kho..." />

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label fw-bold">
                        Ngày cập nhật
                    </label>

                    <input type="text"
                           class="form-control"
                           value="@DateTime.Now.ToString("dd/MM/yyyy HH:mm")"
                           readonly />

                </div>

            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="fas fa-arrow-left"></i>
                    Quay lại

                </a>

                <button type="submit"
                        class="btn btn-success">

                    <i class="fas fa-save"></i>
                    Lưu tồn kho

                </button>

            </div>

        </form>

    </div>

</div>