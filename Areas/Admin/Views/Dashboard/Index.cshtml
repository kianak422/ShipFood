@model ShipFood.API.ViewModels.AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tổng quan";
}

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary h-100 shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-users fa-2x float-end"></i> Người dùng</h5>
                <h2 class="display-6">@Model.TotalUsers</h2>
                <p class="card-text">Tổng số tài khoản</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success h-100 shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-shopping-cart fa-2x float-end"></i> Đơn hàng</h5>
                <h2 class="display-6">@Model.TotalOrders</h2>
                <p class="card-text">Tổng số đơn đã đặt</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning h-100 shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-utensils fa-2x float-end"></i> Món ăn</h5>
                <h2 class="display-6">@Model.TotalProducts</h2>
                <p class="card-text">Tổng số món ăn</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info h-100 shadow">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-money-bill-wave fa-2x float-end"></i> Doanh thu</h5>
                <h2 class="display-6">@Model.TotalRevenue.ToString("N0") <small class="fs-6">đ</small></h2>
                <p class="card-text">Tổng doanh thu</p>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Đơn hàng mới nhất</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr>
                            <td>#@order.Madh</td>
                            <td>@order.Ngaydathang</td>
                            <td class="fw-bold text-success">@order.Tongtien.ToString("N0") đ</td>
                            <td>
                                @{
                                    string badgeClass = "bg-warning text-dark"; // Mặc định Đã đặt, Đang xử lý
                                    if (order.Trangthai == "Đã giao" || order.Trangthai == "Hoàn thành") badgeClass = "bg-success";
                                    else if (order.Trangthai == "Đã hủy" || order.Trangthai == "Hủy bỏ") badgeClass = "bg-danger";
                                    else if (order.Trangthai == "Đang giao") badgeClass = "bg-info text-dark";
                                }
                                <span class="badge @badgeClass">
                                    @order.Trangthai
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
