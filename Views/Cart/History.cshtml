@model List<ShipFood.API.Models.TbDonHang>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Lịch sử đơn hàng</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a class="text-body" href="/Home">Trang chủ</a></li>
                <li class="breadcrumb-item text-dark active" aria-current="page">Lịch sử</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<!-- History Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="section-header text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <h1 class="display-5 mb-3">Đơn hàng của bạn</h1>
            <p>Theo dõi trạng thái các đơn hàng bạn đã đặt.</p>
        </div>
        
        <div class="row g-5">
            <div class="col-12 wow fadeInUp" data-wow-delay="0.1s">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th scope="col">Mã đơn</th>
                                <th scope="col">Ngày đặt</th>
                                <th scope="col">Tổng tiền</th>
                                <th scope="col">Trạng thái</th>
                                <th scope="col">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var order in Model)
                                {
                                    <tr>
                                        <td>#@order.Madh</td>
                                        <td>@order.Ngaydathang.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@order.Tongtien.ToString("N0") đ</td>
                                        <td>
                                            <span class="badge @(order.Trangthai == "Đã giao" ? "bg-success" : (order.Trangthai == "Đã hủy" ? "bg-danger" : "bg-warning"))">
                                                @order.Trangthai
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/Cart/OrderDetail/@order.Madh" class="btn btn-sm btn-outline-primary">Xem</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4">Bạn chưa có đơn hàng nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- History End -->
