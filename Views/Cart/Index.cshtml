@model ShipFood.API.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng";
}

<!-- Cart Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        @if (Model != null && Model.MonAns != null && Model.MonAns.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Sản phẩm</th>
                            <th scope="col">Tên</th>
                            <th scope="col">Giá</th>
                            <th scope="col">Số lượng</th>
                            <th scope="col">Tổng</th>
                            <th scope="col">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.MonAns)
                        {
                            <tr>
                                <th scope="row">
                                    <div class="d-flex align-items-center">
                                        <img src="@(!string.IsNullOrEmpty(item.Hinhanh) ? item.Hinhanh : "/home/img/no-image.jpg")" 
                                             class="img-fluid me-5 rounded-circle" 
                                             style="width: 80px; height: 80px;" 
                                             alt="@item.Tenmon">
                                    </div>
                                </th>
                                <td>
                                    <p class="mb-0 mt-4">@item.Tenmon</p>
                                </td>
                                <td>
                                    <p class="mb-0 mt-4">@item.Giatien.ToString("N0") đ</p>
                                </td>
                                <td>
                                    <div class="input-group quantity mt-4" style="width: 100px;">
                                        <div class="input-group-btn">
                                            <a href="/Cart/GiamSoLuong?maMonAn=@item.Mamon" 
                                               class="btn btn-sm btn-minus rounded-circle bg-light border">
                                                <i class="fa fa-minus"></i>
                                            </a>
                                        </div>
                                        <input type="text" class="form-control form-control-sm text-center border-0" 
                                               value="@item.SoLuong" readonly>
                                        <div class="input-group-btn">
                                            <a href="/Cart/TangSoLuong?maMonAn=@item.Mamon&soLuong=1" 
                                               class="btn btn-sm btn-plus rounded-circle bg-light border">
                                                <i class="fa fa-plus"></i>
                                            </a>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <p class="mb-0 mt-4">@((item.Giatien * item.SoLuong).ToString("N0")) đ</p>
                                </td>
                                <td>
                                    <a href="/Cart/XoaMon?maMonAn=@item.Mamon" 
                                       class="btn btn-md rounded-circle bg-light border mt-4">
                                        <i class="fa fa-times text-danger"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Cart Summary -->
            <div class="row g-4 justify-content-end">
                <div class="col-8"></div>
                <div class="col-sm-8 col-md-7 col-lg-6 col-xl-4">
                    <div class="bg-light rounded">
                        <div class="p-4">
                            <h1 class="display-6 mb-4 fw-bold">Tổng tiền</h1>
                            <div class="d-flex justify-content-between mb-4">
                                <h5 class="mb-0 me-4">Tạm tính:</h5>
                                <p class="mb-0">@Model.TongTien.ToString("N0") đ</p>
                            </div>
                            <div class="d-flex justify-content-between">
                                <h5 class="mb-0 me-4">Phí vận chuyển:</h5>
                                <div class="">
                                    <p class="mb-0">0 đ</p>
                                </div>
                            </div>
                            <hr class="mb-4">
                            <div class="d-flex justify-content-between">
                                <h5 class="mb-0 me-4">Tổng cộng:</h5>
                                <p class="mb-0">@Model.TongTien.ToString("N0") đ</p>
                            </div>
                        </div>
                    </div>
                    <!-- Checkout Link -->
                    <div class="mt-4">
                        <a href="/Cart/Checkout" class="btn border-secondary rounded-pill px-4 py-3 text-primary text-uppercase w-100">
                            Tiến hành thanh toán
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Empty Cart Message -->
            <div class="text-center py-5">
                <i class="fa fa-shopping-cart fa-5x text-muted mb-4"></i>
                <h4>Giỏ hàng trống!</h4>
                <p class="text-muted">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
                <a href="/Home" class="btn btn-primary">Tiếp tục mua sắm</a>
            </div>
        }
    </div>
</div>
<!-- Cart Page End -->
