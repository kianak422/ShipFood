@model ShipFood.API.Models.TbUser
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký - Fastship</title>
    <!-- ... Same Head as Login ... -->
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content="fastship, đặt hàng, giao hàng, ẩm thực, thức ăn" name="keywords" />
    <meta content="Fastship - Nền tảng đặt hàng và giao hàng thức ăn hàng đầu Việt Nam" name="description" />
    
    <link href="/favicon.ico" rel="icon" type="image/x-icon" />
    <link href="/home/img/favicon.ico" rel="icon" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&family=Lora:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css" rel="stylesheet" />

    <link href="/home/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/home/css/login.css" rel="stylesheet" />
</head>

<body class="bg-light">
    <!-- Header Start -->
    <div class="container-fluid bg-white shadow-sm">
        <div class="container">
            <div class="row align-items-center py-3">
                <div class="col-lg-4">
                    <a href="/Home" class="navbar-brand">
                        <h1 style="color: #3CB815 !important;" class="fw-bold text-primary m-0">
                            F<span style="color: #F65005 !important;" class="text-secondary">ast</span>ship
                        </h1>
                    </a>
                </div>
                <div class="col-lg-8 text-end">
                    <span class="text-muted">Đã có tài khoản? </span>
                    <a href="/Home/Login" class="text-primary text-decoration-none fw-bold">Đăng nhập ngay</a>
                </div>
            </div>
        </div>
    </div>
    <!-- Header End -->

    <!-- Signup Form Start -->
    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-lg-7 col-md-9 col-sm-11">
                <div class="card shadow-lg border-0">
                    <div class="card-header text-white text-center py-4">
                        <h3 class="fw-light my-2">
                            <i class="fas fa-user-plus me-2"></i>
                            Đăng ký tài khoản
                        </h3>
                        <p class="mb-0 small">Tham gia cộng đồng Fastship ngay hôm nay</p>
                    </div>
                    <div class="card-body p-4">
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">
                                @ViewBag.Error
                            </div>
                        }
                        <form action="/Home/Signup" method="post" class="needs-validation" novalidate>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control" type="text" name="Hoten" placeholder="Họ và tên" required />
                                        <label>Họ và tên</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control" type="tel" name="Sdt" placeholder="Số điện thoại" required />
                                        <label>Số điện thoại</label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-floating mb-3">
                                <input class="form-control" type="email" name="Email" placeholder="Email" required />
                                <label>Email</label>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control" type="text" name="Username" placeholder="Tên đăng nhập" required />
                                        <label>Tên đăng nhập</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <select class="form-select" name="Loaitaikhoan" required>
                                            <option value="">Chọn loại tài khoản</option>
                                            <option value="Khách hàng" selected>Khách hàng</option>
                                            <option value="Shipper">Shipper</option>
                                        </select>
                                        <label>Loại tài khoản</label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control" type="password" name="Pwd" placeholder="Mật khẩu" required />
                                        <label>Mật khẩu</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control" type="password" name="ConfirmPassword" placeholder="Xác nhận mật khẩu" required />
                                        <label>Xác nhận mật khẩu</label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="d-grid mb-3">
                                <button class="btn btn-primary btn-lg" type="submit">
                                    <i class="fas fa-user-plus me-2"></i>
                                    Đăng ký tài khoản
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Signup Form End -->

    <!-- Footer Start -->
    <div class="container-fluid bg-dark footer mt-5 pt-5">
         <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="text-light">&copy; <a href="#" class="border-bottom text-light">Fastship</a>, Tất cả quyền được bảo lưu.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <span class="text-light">Được thiết kế bởi <a href="#" class="border-bottom text-light">Fastship Team</a></span>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->
</body>
</html>
