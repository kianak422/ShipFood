@model List<ShipFood.API.Models.TbMonAn>

@{
    ViewData["Title"] = "Menu ẩm thực";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="container">
        <h1 class="display-3 mb-3 animated slideInDown">Menu ẩm thực</h1>

        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a class="text-body" href="/Home">Trang chủ</a>
                </li>
                <li class="breadcrumb-item text-dark active">
                    Menu
                </li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->

<!-- Product Start -->
<div class="container-xxl py-5">
    <div class="container">

        <div class="row g-0 gx-5 align-items-end mb-4">
            <div class="col-lg-6">
                <div class="section-header text-start wow fadeInUp"
                     data-wow-delay="0.1s">

                    <h1 class="display-5 mb-3">
                        Thực đơn hôm nay
                    </h1>

                    <p>
                        Khám phá những món ăn ngon, hấp dẫn được chế biến từ
                        những nguyên liệu tươi ngon nhất.
                    </p>
                </div>
            </div>

            <div class="col-lg-3 ms-auto">
                <form method="get" id="sortForm">

                    <input type="hidden"
                           name="txtSearch"
                           value="@Context.Request.Query["txtSearch"]" />

                    <select class="form-select"
                            name="sortOrder"
                            onchange="this.form.submit()">

                        <option value="">Sắp xếp theo</option>

                        <option value="featured"
                                selected="@(ViewBag.SortOrder == "featured")">
                            Nổi bật
                        </option>

                        <option value="bestseller"
                                selected="@(ViewBag.SortOrder == "bestseller")">
                            Bán chạy
                        </option>

                        <option value="discount"
                                selected="@(ViewBag.SortOrder == "discount")">
                            Giảm giá
                        </option>

                        <option value="new"
                                selected="@(ViewBag.SortOrder == "new")">
                            Mới nhất
                        </option>

                        <option value="price_asc"
                                selected="@(ViewBag.SortOrder == "price_asc")">
                            Giá tăng dần
                        </option>

                        <option value="price_desc"
                                selected="@(ViewBag.SortOrder == "price_desc")">
                            Giá giảm dần
                        </option>

                    </select>

                </form>
            </div>
        </div>

        <div class="tab-content">
            <div id="tab-1"
                 class="tab-pane fade show active p-0">

                <div class="row g-4">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="col-xl-3 col-lg-4 col-md-6 wow fadeInUp"
                                 data-wow-delay="0.1s">

                                <div class="product-item h-100 d-flex flex-column">

                                    <div class="position-relative bg-light overflow-hidden">

                                        @{
                                            var imageUrl =
                                            !string.IsNullOrEmpty(item.Hinhanh)
                                            ? item.Hinhanh
                                            : "/home/img/no-image.jpg";
                                        }

                                        <img class="img-fluid w-100"
                                             src="@imageUrl"
                                             alt="@item.Tenmon">

                                        @* Badge *@
                                        @if (item.Noibat)
                                        {
                                            <div class="bg-warning text-dark rounded position-absolute start-0 top-0 m-3 py-1 px-3">
                                                ⭐ Nổi bật
                                            </div>
                                        }
                                        else if (item.Phantramgiam > 0)
                                        {
                                            <div class="bg-danger text-white rounded position-absolute start-0 top-0 m-3 py-1 px-3">
                                                -@item.Phantramgiam%
                                            </div>
                                        }
                                        else if (item.Ngaytao >= DateTime.Now.AddDays(-30))
                                        {
                                            <div class="bg-success text-white rounded position-absolute start-0 top-0 m-3 py-1 px-3">
                                                Mới
                                            </div>
                                        }

                                    </div>

                                    <div class="text-center p-4">

                                        <a class="d-block h5 mb-2"
                                           href="/Home/ChiTiet?id=@item.Mamon">

                                            @item.Tenmon

                                        </a>

                                        <span class="text-primary fw-bold">
                                            @item.Giatien.ToString("N0") đ
                                        </span>

                                    </div>

                                    <div class="d-flex border-top mt-auto">

                                        <small class="w-50 text-center border-end py-2">

                                            <a class="text-body"
                                               href="/Home/ChiTiet?id=@item.Mamon">

                                                <i class="fa fa-eye text-primary me-2"></i>
                                                Xem chi tiết

                                            </a>

                                        </small>

                                        <small class="w-50 text-center py-2">

                                            <a class="text-body"
                                               href="/Cart/ThemMonAn?maMonAn=@item.Mamon&soLuong=1">

                                                <i class="fa fa-shopping-bag text-primary me-2"></i>
                                                Thêm vào giỏ

                                            </a>

                                        </small>

                                    </div>

                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center">
                            <h5>Không tìm thấy món ăn nào phù hợp.</h5>
                        </div>
                    }

                </div>

            </div>
        </div>

    </div>
</div>
<!-- Product End -->