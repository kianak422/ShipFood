@model IEnumerable<ShipFood.API.Models.TbDanhMuc>

@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title"> Danh sách Danh mục</h4>
                <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>
                                    STT
                                </th>
                                <th>
                                    Tên danh mục
                                </th>
                                <th>
                                    Mô tả
                                </th>
                                <th>
                                    Thao tác
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var item in Model)
                            {
                                    <tr>
                                        <td>
                                        @(i++)
                                        </td>
                                        <td>
                                        @Html.DisplayFor(modelItem => item.Tendanhmuc)
                                        </td>
                                        <td>
                                        @Html.DisplayFor(modelItem => item.Mota)
                                        </td>
                                        <td>
                                            <a asp-action="Edit" asp-route-id="@item.Madanhmuc" class="btn btn-warning btn-sm">Sửa</a>
                                            <a asp-action="Delete" asp-route-id="@item.Madanhmuc" class="btn btn-danger btn-sm">Xóa</a>
                                        </td>
                                    </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
