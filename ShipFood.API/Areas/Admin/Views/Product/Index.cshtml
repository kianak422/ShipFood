@model IEnumerable<ShipFood.API.Models.TbMonAn>
@inject ShipFood.API.Services.Flyweight.IconFlyweightFactory IconFactory

@{
    ViewData["Title"] = "Quản lý Món ăn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewData["Categories"] as Dictionary<int, string>;
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title"> Danh sách Món ăn</h4>
                <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>
                                    STT
                                </th>
                                <th>
                                    Tên món
                                </th>
                                <th>
                                    Giá tiền
                                </th>
                                <th>
                                    Danh mục
                                </th>
                                <th>
                                    Hình ảnh
                                </th>
                                <th>
                                    Thao tác
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @(i++)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Tenmon)
                                        
                                        <!-- Sử dụng Flyweight để lấy Icon dùng chung (tiết kiệm RAM) -->
                                        @{
                                            var badgeType = item.Giatien > 50000 ? "Hot" : "New";
                                            var badge = IconFactory.GetIcon(badgeType);
                                        }
                                        @Html.Raw(badge.Render())
                                    </td>
                                    <td>
                                        @item.Giatien.ToString("N0") đ
                                    </td>
                                    <td>
                                        @if (item.Madanhmuc.HasValue && categories != null &&
                                       categories.ContainsKey(item.Madanhmuc.Value))
                                        {
                                            @categories[item.Madanhmuc.Value]
                                        }
                                        else
                                        {
                                            <span>Unknown</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Hinhanh))
                                        {
                                            <img src="@item.Hinhanh" alt="@item.Tenmon"
                                                style="width: 50px; height: 50px; object-fit: cover;" />
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Mamon"
                                            class="btn btn-warning btn-sm">Sửa</a>
                                        <a asp-action="Delete" asp-route-id="@item.Mamon"
                                            class="btn btn-danger btn-sm">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
