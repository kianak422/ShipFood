@model IEnumerable<ShipFood.API.Models.TbUser>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Tài khoản</h6>
        <!-- <a href="#" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Thêm mới</a> -->
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Tên đăng nhập</th>
                        <th>Email / SĐT</th>
                        <th>Loại tài khoản</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@(i++)</td>
                            <td>@item.Username</td>
                            <td>
                                <div><i class="fas fa-envelope me-1"></i> @item.Email</div>
                                <div><i class="fas fa-phone me-1"></i> @item.Sdt</div>
                            </td>
                            <td>
                                @if(item.Loaitaikhoan == "Admin") {
                                    <span class="badge bg-danger rounded-pill px-3">Admin</span>
                                }
                                else if(item.Loaitaikhoan == "Shipper") {
                                    <span class="badge bg-warning text-dark rounded-pill px-3">Shipper</span>
                                }
                                else if(item.Loaitaikhoan == "Restaurant") {
                                    <span class="badge bg-info text-dark rounded-pill px-3">Restaurant</span>
                                }
                                else {
                                    <span class="badge bg-primary rounded-pill px-3">Khách hàng</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Userid" class="btn btn-sm btn-outline-primary rounded-pill me-1">
                                    <i class="fas fa-edit"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Userid" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này không?');">
                                    <i class="fas fa-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
